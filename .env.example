# ═══════════════════════════════════════════════════════════════
# FenixTrace Integration Kit — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every [REQUIRED] value.
# 3. Run:  npm start  or  docker compose up
#
# ═══════════════════════════════════════════════════════════════

# ── IOTA L1 Blockchain ────────────────────────────────────────

# [REQUIRED] Your wallet private key (hex or bech32 iotaprivkey format).
# Generate a new wallet:  node generate-wallet.js
IOTA_PRIVATE_KEY=iotaprivkey1qp...your_key_here

# [REQUIRED] IOTA node RPC endpoint.
#   Testnet : https://api.testnet.iota.cafe
#   Mainnet : https://api.iota.cafe
IOTA_NODE_URL=https://api.testnet.iota.cafe

# [REQUIRED] FenixTrace smart-contract package ID (provided after subscription).
IOTA_PACKAGE_ID=0xYOUR_PACKAGE_ID

# [REQUIRED] Module path — replace only the package ID prefix.
IOTA_MODULE_COMPANY_SUPPLY_CHAIN=0xYOUR_PACKAGE_ID::company_supply_chain

# [REQUIRED] Your company object ID on-chain.
# Find it in your FenixTrace Company Dashboard → Settings, or via
#   curl https://trace.fenixsoftwarelabs.com/api/public/companies
IOTA_COMPANY_OBJECT_ID=0xYOUR_COMPANY_OBJECT_ID

# System clock object (do NOT change).
IOTA_CLOCK_OBJECT=0x6

# Gas budget per product transaction (base units; 100 000 000 = 0.1 IOTA).
IOTA_GAS_BUDGET=100000000

# Gas budget for notarization transactions.
IOTA_NOTARIZATION_GAS_BUDGET=100000000

# Coin type (do NOT change).
IOTA_COIN_TYPE=0x2::iota::IOTA

# ── FenixTrace Platform ──────────────────────────────────────

# [REQUIRED] FenixTrace platform base URL (for notarization API).
#   Local dev  : http://localhost:3000
#   Production : https://trace.fenixsoftwarelabs.com
FENIXTRACE_API_BASE_URL=http://localhost:3000

# Notarization endpoint path (do NOT change).
FENIXTRACE_NOTARIZATION_ENDPOINT=/api/notarization

# ── IPFS / Pinata — YOUR OWN KEYS ────────────────────────────
# You MUST use your own Pinata account.
# Sign up free → https://app.pinata.cloud → API Keys → New Key.

# [REQUIRED]
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_api_key
PINATA_JWT=your_pinata_jwt_token

# Pinata endpoints (do NOT change).
PINATA_API_URL=https://api.pinata.cloud
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# ── Server ────────────────────────────────────────────────────

PORT=3005
NODE_ENV=development

# ── Auto-Processing ──────────────────────────────────────────

# Monitor the uploads/ folder and process new files automatically.
AUTO_PROCESS=true

# Polling interval in minutes.
AUTO_PROCESS_INTERVAL_MINUTES=1

# Cron expression for scheduled batch runs (default: every hour).
CRON_SCHEDULE=0 * * * *

# Folder path to watch.
WATCH_FOLDER_PATH=./uploads

# ── File Limits ──────────────────────────────────────────────

MAX_FILE_SIZE=50MB
ALLOWED_FILE_TYPES=json

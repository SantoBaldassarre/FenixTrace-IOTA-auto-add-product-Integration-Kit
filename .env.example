# ═══════════════════════════════════════════════════════════════
# FenixTrace Integration Kit — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# The kit is a PURE API CLIENT: drop product JSON files in uploads/ and the kit
# POSTs them to FenixTrace. FenixTrace does IPFS upload + on-chain registration
# + notarization SERVER-SIDE. You need NO wallet, NO gas, NO IPFS keys.
#
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the two [REQUIRED] FenixTrace values.
# 3. Run:  npm start   (or  docker compose up)
#
# ═══════════════════════════════════════════════════════════════

# ── FenixTrace (the only required configuration) ─────────────

# [REQUIRED] Your FenixTrace integration API key — generate it from the
# dashboard → "Chiavi API" (format ftrace_<id>_<secret>). FenixTrace signs and
# notarizes every product on-chain for you; the kit never holds a wallet key.
FENIXTRACE_API_KEY=ftrace_<id>_<secret>

# [REQUIRED] FenixTrace platform base URL.
#   Local dev  : http://localhost:3000
#   Production : https://fenixtrace.com
FENIXTRACE_API_BASE_URL=https://fenixtrace.com

# Product endpoint path (do NOT change).
FENIXTRACE_PRODUCTS_ENDPOINT=/api/v1/products

# ── Server ────────────────────────────────────────────────────

PORT=3005
NODE_ENV=development

# ── Auto-Processing ──────────────────────────────────────────

# Monitor the uploads/ folder and process new product files automatically.
AUTO_PROCESS=true

# Polling interval in minutes.
AUTO_PROCESS_INTERVAL_MINUTES=1

# Cron expression for scheduled batch runs (default: every hour).
CRON_SCHEDULE=0 * * * *

# Folder path to watch.
WATCH_FOLDER_PATH=./uploads

# ── File Limits ──────────────────────────────────────────────

MAX_FILE_SIZE=50MB
ALLOWED_FILE_TYPES=json

{
  "name": "fenixtrace-integration-kit",
  "version": "1.0.0",
  "description": "Integration kit for FenixTrace — automate product registration & traceability via the FenixTrace REST API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop fenixtrace-integration",
    "pm2:restart": "pm2 restart fenixtrace-integration",
    "pm2:delete": "pm2 delete fenixtrace-integration",
    "pm2:logs": "pm2 logs fenixtrace-integration",
    "pm2:monit": "pm2 monit",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "product-traceability",
    "supply-chain",
    "eudr",
    "digital-product-passport",
    "compliance",
    "rest-api",
    "integration",
    "fenixtrace"
  ],
  "author": "FenixTrace Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pm2": "^5.3.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
